#!/usr/bin/env bash
# toolbelt launcher — runs the bundled CLI under Bun so native deps
# (onnxruntime-node, fastembed) keep their dylibs intact. The
# fully-static `bun build --compile` binary at bin/toolbelt-static is
# only suitable for keyword-only workflows; it breaks Layer 1 / Layer 2.

set -e

# Resolve symlinks so DIR points at the actual cli/bin directory even
# when this script is invoked via ~/.local/bin/toolbelt -> repo path.
SCRIPT="${BASH_SOURCE[0]}"
while [ -h "$SCRIPT" ]; do
  TARGET="$( readlink "$SCRIPT" )"
  if [[ "$TARGET" == /* ]]; then
    SCRIPT="$TARGET"
  else
    SCRIPT_DIR="$( cd -P "$( dirname "$SCRIPT" )" && pwd )"
    SCRIPT="$SCRIPT_DIR/$TARGET"
  fi
done
DIR="$( cd -P "$( dirname "$SCRIPT" )" && pwd )"
BUNDLE="$DIR/toolbelt.bundle.js"
SOURCE="$DIR/../src/index.ts"

# Resolve bun (mise shim → PATH → common install locations)
if [ -x "$HOME/.local/share/mise/shims/bun" ]; then
  BUN="$HOME/.local/share/mise/shims/bun"
elif command -v bun >/dev/null 2>&1; then
  BUN="$(command -v bun)"
elif [ -x "$HOME/.bun/bin/bun" ]; then
  BUN="$HOME/.bun/bin/bun"
elif [ -x "/opt/homebrew/bin/bun" ]; then
  BUN="/opt/homebrew/bin/bun"
else
  echo "error: bun not found on PATH or common install locations" >&2
  exit 127
fi

# Prefer pre-built bundle; fall back to TS source if bundle missing.
if [ -f "$BUNDLE" ]; then
  exec "$BUN" "$BUNDLE" "$@"
elif [ -f "$SOURCE" ]; then
  exec "$BUN" "$SOURCE" "$@"
else
  echo "error: neither $BUNDLE nor $SOURCE exists" >&2
  exit 1
fi
